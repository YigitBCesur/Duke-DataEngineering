# ~/.zshrc - COACH PEGASUS

# --- 1. OH MY ZSH ---
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="agnoster"
plugins=(git python pip docker docker-compose virtualenv zsh-autosuggestions zsh-syntax-highlighting)
source $ZSH/oh-my-zsh.sh

# --- 2. GÜVENLİK VE GEÇMİŞ AYARLARI ---
HISTCONTROL=ignoreboth
export HISTIGNORE="export *:ls:exit:history"
HISTSIZE=1000
HISTFILESIZE=2000

# --- 3. COACH PEGASUS ÖZEL YAPILANDIRMA ---
[ -f $HOME/apikeys.sh ] && source $HOME/apikeys.sh

# --- 4. KISA YOLLAR (ALIASES) ---
alias DEprojects='cd $HOME/Projects/Duke-DataEngineering'
alias cls='clear'
alias ll='ls -alF'

# --- 5. OTOMASYON (AÇILIŞTA ÇALIŞACAKLAR) ---
cd $HOME/Projects/Duke-DataEngineering
[ -d $HOME/de_venv ] && source $HOME/de_venv/bin/activate
